{
  "name": "Business Programming - Web Coding Environment",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:latest",
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "customizations": {
    "codespaces": {
      "openFiles": ["index.html"]
    },
    "vscode": {
      "extensions": [
        "ms-vscode.live-server",
        "formulahendry.auto-rename-tag",
        "formulahendry.auto-close-tag",
        "ecmel.vscode-html-css",
        "esbenp.prettier-vscode",
        "usernamehw.errorlens",
        "oderwat.indent-rainbow",
        "seunlanlege.action-buttons",
        "mathematic.vscode-pdf",
        "github.github-vscode-theme"
      ],
      "settings": {
        "files.autoSave": "afterDelay",
        "editor.formatOnSave": true,
        "editor.fontSize": 14,
        "editor.minimap.enabled": false,
        "editor.fontWeight": "normal",
        "editor.tabSize": 2,
        "editor.renderWhitespace": "boundary",
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "workbench.startupEditor": "none",
        "workbench.colorTheme": "GitHub Dark Default",
        "git.autofetch": true,
        "livePreview.openPreviewTarget": "Embedded Preview",
        "livePreview.autoRefreshPreview": "On All Changes",
        "terminal.integrated.shellIntegration.decorationsEnabled": "both",
        "terminal.integrated.minimumContrastRatio": 4.5,
        "terminal.integrated.cursorStyle": "line",
        "terminal.integrated.cursorBlinking": true,
        "terminal.integrated.fontWeight": "bold",
        "workbench.editorAssociations": {
          "*.md": "vscode.markdown.preview.editor"
        },
        "workbench.colorCustomizations": {
          "terminal.background": "#0d1117",
          "terminal.foreground": "#e6edf3",
          "terminalCursor.foreground": "#58a6ff",
          "terminal.ansiGreen": "#3fb950",
          "terminal.ansiBrightGreen": "#56d364",
          "terminal.ansiYellow": "#d29922",
          "terminal.ansiBrightYellow": "#e3b341",
          "terminal.ansiCyan": "#39c5cf",
          "terminal.ansiBrightCyan": "#56d4dd",
          "terminal.ansiBrightWhite": "#ffffff",
          "terminal.selectionBackground": "#264f7855"
        },
        "files.exclude": {
          ".devcontainer": true,
          ".gitignore": true,
          ".vscode": true,
          "README.md": true,
          "LICENSE": true,
          "node_modules": true
        },
        "actionButtons": {
          "reloadButton": null,
          "defaultColor": "#ffffff",
          "loadNpmCommands": false,
          "commands": [
            {
              "name": "📦 Download my work",
              "color": "#56d364",
              "singleInstance": true,
              "command": "bash .devcontainer/download.sh"
            },
            {
              "name": "📂 Restore my work",
              "color": "#58a6ff",
              "singleInstance": true,
              "command": "bash .devcontainer/restore.sh"
            }
          ]
        }
      }
    }
  }
}
